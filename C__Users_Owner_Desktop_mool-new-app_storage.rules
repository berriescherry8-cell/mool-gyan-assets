
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This rule matches any file in your storage bucket.
    match /{allPaths=**} {
      // PUBLIC READ ACCESS:
      // Allow any user (authenticated or not) to view files. This is necessary
      // for your app's images (book covers, gallery photos) to be publicly visible.
      // Security for these public files relies on the fact that the download URLs
      // are long, complex, and unguessable.
      allow read: if true;
      
      // ADMIN-ONLY WRITE ACCESS:
      // Allow create, update, and delete operations only if the user is signed in
      // and their email matches the specified admin email address. This prevents
      // anyone else from uploading, overwriting, or deleting your files.
      allow write: if request.auth != null && request.auth.token.email == 'sharmadevendra715@gmail.com';
    }
  }
}
